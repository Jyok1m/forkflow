// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id Int @default(autoincrement()) @id
  publicId String @unique @default(uuid(7))
  name String
  line1 String
  line2 String?
  city String
  postCode String
  country String
  bannerUrl String
  style String @default("")
  tables Table[]
  serviceSlots ServiceSlot[]
  admin Diner @relation(fields: [adminId], references: [id])
  adminId Int
}

model Table {
  id Int @default(autoincrement()) @id
  publicId String @unique @default(uuid(7))
  number Int
  seats Int
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId Int
}

enum Period {
  BREAKFAST
  BRUNCH
  LUNCH
  TEA
  DINNER
  ALL_DAY
}

model ServiceSlot {
  id Int @default(autoincrement()) @id
  publicId String @unique @default(uuid(7))
  date DateTime
  period Period
  openingTime DateTime @db.Time
  closingTime DateTime @db.Time
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId Int
  reservations Reservation[]
  capacity Int
}

enum Status {
  PREBOOKED
  BOOKED
  COMPLETE
  CANCELED
  NO_SHOW
}

model Reservation {
  id Int @default(autoincrement()) @id
  publicId String @unique @default(uuid(7))
  diner Diner @relation(fields: [dinerId], references: [id])
  dinerId Int
  serviceSlot ServiceSlot @relation(fields: [serviceSlotId], references: [id])
  serviceSlotId Int
  pax Int
  status Status
  @@unique([dinerId, serviceSlotId])
}

model Diner {
  id Int @default(autoincrement()) @id
  publicId String @unique @default(uuid(7))
  email String @unique
  phone String @unique
  passwordHash String? // null = guest account, present = registered user
  firstName String
  lastName String
  reservations Reservation[]
  restaurants Restaurant[]
}